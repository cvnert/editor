{
  "name": "omnibox-editor",
  "private": false,
  "version": "0.0.1",
  "description": "A OmniBox editor",
  "license": "MIT",
  "type": "module",
  "main": "./dist/omnibox-editor.umd.cjs",
  "module": "./dist/omnibox-editor.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/omnibox-editor.js",
      "require": "./dist/omnibox-editor.umd.cjs"
    },
    "./style.css": "./dist/omnibox-editor.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "block-editor",
    "tiptap",
    "prosemirror",
    "react",
    "editor",
    "rich-text",
    "tailwindcss"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build && node ../../scripts/flatten-css-layers.mjs && tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pack:local": "pnpm pack --pack-destination dist-pack"
  },
  "dependencies": {
    "@ariakit/react": "^0.4.29",
    "@base-ui/react": "^1.6.0",
    "@floating-ui/react": "^0.27.19",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-popover": "^1.1.17",
    "@tiptap/core": "^3.27.1",
    "@tiptap/extension-code-block": "3.27.1",
    "@tiptap/extension-collaboration": "3.27.1",
    "@tiptap/extension-collaboration-caret": "3.27.1",
    "@tiptap/extension-color": "^3.27.1",
    "@tiptap/extension-drag-handle": "^3.27.1",
    "@tiptap/extension-drag-handle-react": "^3.27.1",
    "@tiptap/extension-emoji": "^3.27.1",
    "@tiptap/extension-highlight": "^3.27.1",
    "@tiptap/extension-horizontal-rule": "^3.27.1",
    "@tiptap/extension-image": "^3.27.1",
    "@tiptap/extension-list": "^3.27.1",
    "@tiptap/extension-mathematics": "^3.27.1",
    "@tiptap/extension-mention": "^3.27.1",
    "@tiptap/extension-subscript": "^3.27.1",
    "@tiptap/extension-superscript": "^3.27.1",
    "@tiptap/extension-table": "^3.27.1",
    "@tiptap/extension-table-of-contents": "^3.27.1",
    "@tiptap/extension-text-align": "^3.27.1",
    "@tiptap/extension-text-style": "^3.27.1",
    "@tiptap/extension-typography": "^3.27.1",
    "@tiptap/extension-unique-id": "^3.27.1",
    "@tiptap/extensions": "^3.27.1",
    "@tiptap/markdown": "3.27.1",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "@tiptap/suggestion": "^3.27.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "echarts": "^6.0.0",
    "is-hotkey": "^0.2.0",
    "katex": "0.16.47",
    "lodash.throttle": "^4.1.1",
    "lucide-react": "^0.561.0",
    "mermaid": "^11.12.2",
    "react-hotkeys-hook": "^5.3.2",
    "react-textarea-autosize": "^8.5.9",
    "yjs": "^13.6.31"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/is-hotkey": "^0.1.10",
    "@types/lodash.throttle": "^4.1.9",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "vitest": "^4.0.16"
  }
}
